{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.zylora.dev/function-yaml/v1.json",
  "title": "function.yaml",
  "description": "Zylora function definition metadata file. Typically generated by `zylora init` or the @zylora.fn() decorator.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "entry_point", "gpu_type"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 100,
      "pattern": "^[a-z0-9][a-z0-9-]{0,98}[a-z0-9]$",
      "description": "Lowercase alphanumeric function slug (hyphens allowed, no spaces)",
      "examples": ["embed-text", "classify-image", "llm-chat"]
    },
    "description": {
      "type": "string",
      "maxLength": 500,
      "description": "Human-readable description shown in the dashboard"
    },
    "entry_point": {
      "type": "string",
      "pattern": "^[a-zA-Z_][a-zA-Z0-9_.]*:[a-zA-Z_][a-zA-Z0-9_]*$",
      "description": "Python module:callable path. The callable receives a dict and returns a dict.",
      "examples": ["main:handler", "src.inference:run", "app:predict"]
    },
    "gpu_type": {
      "type": "string",
      "enum": [
        "t4",
        "l4",
        "rtx4090",
        "a100_40gb",
        "a100_80gb",
        "l40s",
        "h100",
        "h200",
        "b200",
        "mi300x"
      ],
      "description": "GPU instance type for this function"
    },
    "gpu_count": {
      "type": "integer",
      "minimum": 1,
      "default": 1
    },
    "runtime": {
      "type": "string",
      "enum": [
        "python310",
        "python311",
        "python312",
        "python313",
        "node20",
        "node22",
        "custom"
      ],
      "default": "python312"
    },
    "python_version": {
      "type": "string",
      "pattern": "^3\\.1[0-9]$",
      "examples": ["3.12"]
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "pip package specifiers",
      "examples": [["torch==2.2.0", "transformers>=4.38"]]
    },
    "requirements_file": {
      "type": "string",
      "default": "requirements.txt"
    },
    "dockerfile": {
      "type": "string",
      "description": "Path to Dockerfile (relative to project root). Overrides runtime."
    },
    "scaling": {
      "type": "object",
      "additionalProperties": false,
      "description": "Auto-scaling configuration",
      "properties": {
        "min_instances": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "0 = scale to zero (cold start on first request after idle)"
        },
        "max_instances": {
          "type": "integer",
          "minimum": 1,
          "default": 10
        },
        "concurrency": {
          "type": "integer",
          "minimum": 1,
          "default": 1,
          "description": "Simultaneous requests per instance. Increase carefully — GPU memory is shared."
        }
      }
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3600,
      "default": 300,
      "description": "Maximum allowed execution time. Invocations exceeding this are terminated."
    },
    "model": {
      "type": "string",
      "description": "Name of a model in the Zylora model registry to mount. Passed to your handler."
    },
    "secrets": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z][A-Z0-9_]*$"
      },
      "description": "Secret names to inject. Must be created via `zylora secrets set <NAME>` first.",
      "examples": [["HF_TOKEN", "OPENAI_API_KEY"]]
    },
    "env": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Non-secret environment variables available to the function at runtime"
    },
    "visibility": {
      "type": "string",
      "enum": ["public", "private", "unlisted"],
      "default": "private",
      "description": "public = callable by anyone with the URL. private = only your API keys."
    },
    "schedule": {
      "type": "string",
      "description": "Cron expression (UTC) to invoke this function on a schedule. E.g. '0 3 * * *'",
      "examples": ["0 * * * *", "*/30 * * * *"]
    },
    "retry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_retries": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5,
          "default": 0
        },
        "delay_ms": {
          "type": "integer",
          "minimum": 100,
          "default": 1000,
          "description": "Delay between retries in milliseconds"
        }
      }
    },
    "async": {
      "type": "object",
      "additionalProperties": false,
      "description": "Configuration for async invocations",
      "properties": {
        "webhook_url": {
          "type": "string",
          "format": "uri",
          "description": "POST completed result to this URL when async invocation finishes"
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "Arbitrary key-value metadata for organizational purposes"
    }
  }
}
